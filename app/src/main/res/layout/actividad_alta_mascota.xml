<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarAlta"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2E7D32"
        app:title="Registrar Mascota"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <EditText
                android:id="@+id/etMicrochipMascota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Número de Microchip"
                android:inputType="text"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etNombreMascota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre del perro"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etFechaNacimientoMascota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fecha nacimiento (DD/MM/AAAA)"
                android:inputType="date"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etPesoMascota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Peso actual (Kg)"
                android:inputType="numberDecimal"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nivel de Actividad:"
                android:textColor="#555555"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spNivelActividad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Patologías Médicas:"
                android:textColor="#555555"
                android:textSize="14sp"
                android:layout_marginBottom="4dp"/>

            <Button
                android:id="@+id/btnSeleccionarPatologias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seleccionar patologías..."
                android:backgroundTint="#E0E0E0"
                android:textColor="#333333"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/btnGuardarMascota"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#2E7D32"
                android:text="REGISTRAR MASCOTA"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="28dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>