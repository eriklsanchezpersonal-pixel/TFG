<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarDetalle"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#2E7D32"
        app:titleTextColor="#FFFFFF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvDetalleNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nombre: ..."
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="10dp"
                    android:background="#EEEEEE" />

                <TextView
                    android:id="@+id/tvDetalleMicrochip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Microchip: ..."
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="10dp"
                    android:background="#EEEEEE" />

                <TextView
                    android:id="@+id/tvDetalleFecha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="F. Nacimiento: ..."
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="10dp"
                    android:background="#EEEEEE" />

                <TextView
                    android:id="@+id/tvDetallePeso"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Peso: ... kg"
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="10dp"
                    android:background="#EEEEEE" />

                <TextView
                    android:id="@+id/tvDetalleActividad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Actividad: ..."
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="10dp"
                    android:background="#EEEEEE" />

                <TextView
                    android:id="@+id/tvDetallePatologia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Patología: Cargando..."
                    android:textColor="#D32F2F"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Recetas Asignadas:"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:textSize="16sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecetasAsignadas"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:background="#FFFFFF"
            android:padding="4dp" />

        <Button
            android:id="@+id/btnVerDieta"
            style="@style/EstiloBotonMascota"
            app:backgroundTint="#2E7D32"
            android:text="Ver Dieta Recomendada" />

        <Button
            android:id="@+id/btnModificarMascota"
            style="@style/EstiloBotonMascota"
            android:layout_height="48dp"
            android:text="Modificar mascota"
            app:backgroundTint="#FF9800" />

        <Button
            android:id="@+id/btnBorrarMascota"
            style="@style/EstiloBotonMascota"
            app:backgroundTint="#D32F2F"
            android:text="Eliminar mascota" />
    </LinearLayout>
</LinearLayout>