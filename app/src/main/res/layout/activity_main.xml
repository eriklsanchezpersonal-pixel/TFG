<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2E7D32"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"> <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mis Mascotas"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Selecciona tu mascota para gestionar su dieta"
            android:textColor="#E0E0E0"
            android:textSize="14sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMascotas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutHeader"
        android:paddingVertical="8dp"
        android:clipToPadding="false"/>

    <TextView
        android:id="@+id/tvListaVacia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_margin="32dp"
        android:gravity="center"
        android:text="No tienes ninguna mascota registrada.\n¡Pulsa el botón + para añadir una!"
        android:textColor="#888888"
        android:textSize="16sp"
        android:visibility="gone" /> <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabPerfil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="12dp"
        app:backgroundTint="#1B5E20"
        app:tint="#FFFFFF"
        app:fabSize="mini"
        app:srcCompat="@android:drawable/ic_menu_myplaces"
        android:contentDescription="Perfil" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAnadirMascota"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="16dp"
        app:backgroundTint="#2E7D32"
        app:tint="#FFFFFF"
        app:srcCompat="@android:drawable/ic_input_add"
        android:contentDescription="Añadir Mascota" />
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCalendario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_margin="16dp"
        app:backgroundTint="#2E7D32"
        app:tint="#FFFFFF"
        app:srcCompat="@android:drawable/ic_menu_agenda"
        android:contentDescription="Calendario de Citas" />
</RelativeLayout>